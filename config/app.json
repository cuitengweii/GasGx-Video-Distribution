    "fallback_replies": [
      "\u8c22\u8c22\u559c\u6b22\uff0c\u4e00\u8d77\u89c1\u8bc1\u66f4\u591a\u7cbe\u5f69\u3002",
      "\u611f\u8c22\u5173\u6ce8\uff0c\u6b22\u8fce\u7ee7\u7eed\u4ea4\u6d41\u60f3\u6cd5\u3002",
