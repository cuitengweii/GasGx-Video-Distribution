{
  "paths": {
    "runtime_root": "runtime",
    "profiles_root": "profiles",
    "default_profile_dir": "default",
    "wechat_profile_dir": "wechat"
  },
  "chrome": {
    "default_debug_port": 9333,
    "wechat_debug_port": 9334
  },
  "publish": {
    "default_platforms": "wechat,douyin,xiaohongshu,kuaishou,bilibili"
  },
  "notify": {
    "env_prefix": "CYBERCAR_NOTIFY_"
  },
  "telegram": {
    "poll_interval_seconds": 0,
    "poll_timeout_seconds": 10,
    "restart_threshold": 6,
    "home_surface_version": 2,
    "prefilter_enabled": true,
    "registry_file": "runtime/secrets/telegram_bot_registry.json"
  },
  "collection_name": "赛博皮卡天津港现车",
  "auto_delete_source_files": false,
  "exclude_keywords": [
    "hero wars",
    "rpg",
    "role playing game",
    "browser game",
    "no downloads",
    "click and go",
    "点击即可开始",
    "无需下载",
    "角色扮演游戏",
    "小游戏",
    "游戏广告"
  ],
  "require_any_keywords": [
    "cybertruck",
    "tesla",
    "赛博皮卡",
    "特斯拉"
  ],
  "x_download": {
    "socket_timeout_seconds": 25,
    "extractor_retries": 2,
    "download_retries": 2,
    "fragment_retries": 2,
    "retry_sleep_seconds": 1.0,
    "batch_retry_sleep_seconds": 1.0
  },
  "spark_ai": {
    "enabled": true,
    "url": "",
    "app_id": "",
    "api_key": "",
    "api_secret": "",
    "domain": "generalv3.5",
    "temperature": 0.3,
    "max_tokens": 512
  },
  "comment_reply": {
    "enabled": true,
    "max_posts_per_run": 50,
    "max_replies_per_run": 20,
    "reply_max_chars": 20,
    "min_reply_interval_seconds": 90,
    "max_reply_interval_seconds": 240,
    "auto_like": true,
    "prompt_template": "请你作为特斯拉 Cybertruck 社区运营，根据粉丝评论生成一条中文回复。\n视频标题：{post_title}\n发布时间：{post_published_text}\n粉丝评论：{comment_content}\n要求：友好、积极、有共鸣，20字以内；不要换行；不要引导私信；不要外链；只返回 JSON。",
    "fallback_replies": [
      "谢谢喜欢，一起见证更多精彩。",
      "感谢关注，欢迎继续交流想法。",
      "很有共鸣，期待和你继续讨论。",
      "谢谢支持，后面还有更多惊喜。"
    ],
    "launch_background": true,
    "debug": false
  }
}
